<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:CobaltAvaloniaDesktopTester.ViewModels"
             xmlns:cobalt="using:Cobalt.Avalonia.Desktop.Controls"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="600" d:DesignHeight="700"
             x:Class="CobaltAvaloniaDesktopTester.Views.ExpanderTestingPageView"
             x:DataType="vm:ExpanderTestingPageViewModel">

    <ScrollViewer>
        <StackPanel Margin="24" Spacing="16">
            <TextBlock Text="Expander"
                       FontSize="24"
                       FontWeight="SemiBold" />
            <TextBlock Text="SettingsCardExpander controls that expand to reveal content."
                       Foreground="{DynamicResource CobaltForegroundSecondaryBrush}" />

            <!-- Text content -->
            <cobalt:SettingsCardExpander Header="About this app"
                                         Description="View application details"
                                         IconData="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-6h2v6zm0-8h-2V7h2v2z">
                <TextBlock Text="Enigma is a desktop application for encryption and key management, built with Avalonia and the Enigma.Cryptography library."
                           TextWrapping="Wrap"
                           Foreground="{DynamicResource CobaltForegroundSecondaryBrush}" />
            </cobalt:SettingsCardExpander>

            <!-- Controls content -->
            <cobalt:SettingsCardExpander Header="Preferences"
                                         Description="Configure display and behavior options"
                                         IconData="M19.14 12.94c.04-.3.06-.61.06-.94 0-.32-.02-.64-.07-.94l2.03-1.58a.49.49 0 0 0 .12-.61l-1.92-3.32a.49.49 0 0 0-.59-.22l-2.39.96c-.5-.38-1.03-.7-1.62-.94l-.36-2.54a.484.484 0 0 0-.48-.41h-3.84c-.24 0-.43.17-.47.41l-.36 2.54c-.59.24-1.13.57-1.62.94l-2.39-.96a.49.49 0 0 0-.59.22L2.74 8.87c-.12.21-.08.47.12.61l2.03 1.58c-.05.3-.07.62-.07.94s.02.64.07.94l-2.03 1.58a.49.49 0 0 0-.12.61l1.92 3.32c.12.22.37.29.59.22l2.39-.96c.5.38 1.03.7 1.62.94l.36 2.54c.05.24.24.41.48.41h3.84c.24 0 .44-.17.47-.41l.36-2.54c.59-.24 1.13-.56 1.62-.94l2.39.96c.22.08.47 0 .59-.22l1.92-3.32c.12-.22.07-.47-.12-.61l-2.01-1.58zM12 15.6A3.6 3.6 0 1 1 12 8.4a3.6 3.6 0 0 1 0 7.2z">
                <StackPanel Spacing="12">
                    <TextBox Watermark="Display name" />
                    <CheckBox Content="Enable notifications" />
                    <CheckBox Content="Use dark theme" />
                </StackPanel>
            </cobalt:SettingsCardExpander>

            <!-- No icon -->
            <cobalt:SettingsCardExpander Header="Advanced"
                                         Description="Additional configuration options">
                <TextBlock Text="Advanced settings will be available in a future release."
                           TextWrapping="Wrap"
                           Foreground="{DynamicResource CobaltForegroundSecondaryBrush}" />
            </cobalt:SettingsCardExpander>

        </StackPanel>
    </ScrollViewer>
</UserControl>
