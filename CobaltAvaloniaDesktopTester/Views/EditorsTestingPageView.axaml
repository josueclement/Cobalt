<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:CobaltAvaloniaDesktopTester.ViewModels"
             xmlns:editors="using:Cobalt.Avalonia.Desktop.Controls.Editors"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="600" d:DesignHeight="700"
             x:Class="CobaltAvaloniaDesktopTester.Views.EditorsTestingPageView"
             x:DataType="vm:EditorsTestingPageViewModel">

    <ScrollViewer>
        <StackPanel Margin="24" Spacing="24">
            <TextBlock Text="Editors"
                       FontSize="24"
                       FontWeight="SemiBold" />
            <TextBlock Text="Typed editor controls with input validation, formatting, and action areas."
                       Foreground="{DynamicResource CobaltForegroundSecondaryBrush}" />

            <!-- TextEditor -->
            <StackPanel Spacing="8">
                <TextBlock Text="TextEditor"
                           FontSize="16"
                           FontWeight="SemiBold" />
                <editors:TextEditor Title="Label"
                                    Watermark="Enter text..."
                                    Text="{Binding TextValue, Mode=TwoWay}"
                                    Unit="txt" />
                <editors:TextEditor Title="With action content"
                                    Watermark="Type something..."
                                    Text="{Binding TextValue, Mode=TwoWay}">
                    <editors:TextEditor.ActionContent>
                        <Button Content="Go"
                                Padding="6,2"
                                FontSize="12" />
                    </editors:TextEditor.ActionContent>
                </editors:TextEditor>
                <editors:TextEditor Watermark="No title" />
                <TextBlock Text="{Binding TextValue, StringFormat='Bound value: {0}'}"
                           FontSize="12"
                           Foreground="{DynamicResource CobaltForegroundSecondaryBrush}" />
            </StackPanel>

            <!-- IntEditor -->
            <StackPanel Spacing="8">
                <TextBlock Text="IntEditor"
                           FontSize="16"
                           FontWeight="SemiBold" />
                <editors:IntEditor Title="Size"
                                   Watermark="Enter integer..."
                                   Value="{Binding IntValue, Mode=TwoWay}"
                                   Minimum="-100"
                                   Maximum="100"
                                   Unit="px" />
                <TextBlock Text="{Binding IntValue, StringFormat='Bound value: {0}'}"
                           FontSize="12"
                           Foreground="{DynamicResource CobaltForegroundSecondaryBrush}" />
            </StackPanel>

            <!-- UIntEditor -->
            <StackPanel Spacing="8">
                <TextBlock Text="UIntEditor"
                           FontSize="16"
                           FontWeight="SemiBold" />
                <editors:UIntEditor Title="Count"
                                    Watermark="Enter unsigned integer..."
                                    Value="{Binding UintValue, Mode=TwoWay}"
                                    Minimum="0"
                                    Maximum="1000"
                                    Unit="items" />
                <TextBlock Text="{Binding UintValue, StringFormat='Bound value: {0}'}"
                           FontSize="12"
                           Foreground="{DynamicResource CobaltForegroundSecondaryBrush}" />
            </StackPanel>

            <!-- ShortEditor -->
            <StackPanel Spacing="8">
                <TextBlock Text="ShortEditor"
                           FontSize="16"
                           FontWeight="SemiBold" />
                <editors:ShortEditor Title="Temperature"
                                     Watermark="Enter short integer..."
                                     Value="{Binding ShortValue, Mode=TwoWay}"
                                     Minimum="-273"
                                     Maximum="1000"
                                     Unit="°C" />
                <TextBlock Text="{Binding ShortValue, StringFormat='Bound value: {0}'}"
                           FontSize="12"
                           Foreground="{DynamicResource CobaltForegroundSecondaryBrush}" />
            </StackPanel>

            <!-- UShortEditor -->
            <StackPanel Spacing="8">
                <TextBlock Text="UShortEditor"
                           FontSize="16"
                           FontWeight="SemiBold" />
                <editors:UShortEditor Title="Port"
                                      Watermark="Enter port number..."
                                      Value="{Binding UshortValue, Mode=TwoWay}"
                                      Minimum="1024"
                                      Maximum="65535"
                                      Unit="port" />
                <TextBlock Text="{Binding UshortValue, StringFormat='Bound value: {0}'}"
                           FontSize="12"
                           Foreground="{DynamicResource CobaltForegroundSecondaryBrush}" />
            </StackPanel>

            <!-- LongEditor -->
            <StackPanel Spacing="8">
                <TextBlock Text="LongEditor"
                           FontSize="16"
                           FontWeight="SemiBold" />
                <editors:LongEditor Title="Timestamp"
                                    Watermark="Enter long integer..."
                                    Value="{Binding LongValue, Mode=TwoWay}"
                                    Minimum="0"
                                    Unit="ticks" />
                <TextBlock Text="{Binding LongValue, StringFormat='Bound value: {0}'}"
                           FontSize="12"
                           Foreground="{DynamicResource CobaltForegroundSecondaryBrush}" />
            </StackPanel>

            <!-- ULongEditor -->
            <StackPanel Spacing="8">
                <TextBlock Text="ULongEditor"
                           FontSize="16"
                           FontWeight="SemiBold" />
                <editors:ULongEditor Title="File size"
                                     Watermark="Enter unsigned integer..."
                                     Value="{Binding UlongValue, Mode=TwoWay}"
                                     Maximum="999999"
                                     Unit="bytes" />
                <TextBlock Text="{Binding UlongValue, StringFormat='Bound value: {0}'}"
                           FontSize="12"
                           Foreground="{DynamicResource CobaltForegroundSecondaryBrush}" />
            </StackPanel>

            <!-- SingleEditor -->
            <StackPanel Spacing="8">
                <TextBlock Text="SingleEditor"
                           FontSize="16"
                           FontWeight="SemiBold" />
                <editors:SingleEditor Title="Ratio"
                                      Watermark="Enter float..."
                                      Value="{Binding SingleValue, Mode=TwoWay}"
                                      Digits="3"
                                      Minimum="0"
                                      Maximum="10" />
                <TextBlock Text="{Binding SingleValue, StringFormat='Bound value: {0}'}"
                           FontSize="12"
                           Foreground="{DynamicResource CobaltForegroundSecondaryBrush}" />
            </StackPanel>

            <!-- DoubleEditor -->
            <StackPanel Spacing="8">
                <TextBlock Text="DoubleEditor"
                           FontSize="16"
                           FontWeight="SemiBold" />
                <editors:DoubleEditor Title="Distance"
                                      Watermark="Enter decimal..."
                                      Value="{Binding DoubleValue, Mode=TwoWay}"
                                      Digits="2"
                                      Minimum="0"
                                      Maximum="1000"
                                      Unit="mm" />
                <editors:DoubleEditor Title="Speed"
                                      Watermark="No constraints"
                                      Value="{Binding DoubleValue, Mode=TwoWay}"
                                      Unit="m/s" />
                <TextBlock Text="{Binding DoubleValue, StringFormat='Bound value: {0}'}"
                           FontSize="12"
                           Foreground="{DynamicResource CobaltForegroundSecondaryBrush}" />
            </StackPanel>

            <!-- DecimalEditor -->
            <StackPanel Spacing="8">
                <TextBlock Text="DecimalEditor"
                           FontSize="16"
                           FontWeight="SemiBold" />
                <editors:DecimalEditor Title="Price"
                                       Watermark="Enter price..."
                                       Value="{Binding DecimalValue, Mode=TwoWay}"
                                       Digits="2"
                                       Minimum="0"
                                       Maximum="99999.99"
                                       Unit="USD" />
                <TextBlock Text="{Binding DecimalValue, StringFormat='Bound value: {0}'}"
                           FontSize="12"
                           Foreground="{DynamicResource CobaltForegroundSecondaryBrush}" />
            </StackPanel>

            <!-- MultiLineTextEditor -->
            <StackPanel Spacing="8">
                <TextBlock Text="MultiLineTextEditor"
                           FontSize="16"
                           FontWeight="SemiBold" />
                <editors:MultiLineTextEditor Title="Notes"
                                             Watermark="Enter multi-line text..."
                                             Text="{Binding MultiLineTextValue, Mode=TwoWay}" />
                <editors:MultiLineTextEditor Title="With action"
                                             Watermark="Type something..."
                                             Text="{Binding MultiLineTextValue, Mode=TwoWay}"
                                             Unit="md">
                    <editors:MultiLineTextEditor.ActionContent>
                        <Button Content="Format"
                                Padding="6,2"
                                FontSize="12" />
                    </editors:MultiLineTextEditor.ActionContent>
                </editors:MultiLineTextEditor>
                <TextBlock Text="{Binding MultiLineTextValue, StringFormat='Bound value: {0}'}"
                           FontSize="12"
                           Foreground="{DynamicResource CobaltForegroundSecondaryBrush}" />
            </StackPanel>

            <!-- HexadecimalEditor -->
            <StackPanel Spacing="8">
                <TextBlock Text="HexadecimalEditor"
                           FontSize="16"
                           FontWeight="SemiBold" />
                <editors:HexadecimalEditor Title="Raw bytes (hex)"
                                           Watermark="Enter hex bytes (e.g. 0A FF 1B)..."
                                           Value="{Binding HexValue, Mode=TwoWay}" />
                <TextBlock Text="{Binding HexValue.Length, StringFormat='Bound value: {0} bytes', FallbackValue='Bound value: (null)'}"
                           FontSize="12"
                           Foreground="{DynamicResource CobaltForegroundSecondaryBrush}" />
            </StackPanel>

            <!-- Base64Editor -->
            <StackPanel Spacing="8">
                <TextBlock Text="Base64Editor"
                           FontSize="16"
                           FontWeight="SemiBold" />
                <editors:Base64Editor Title="Encoded data"
                                      Watermark="Enter Base64 string..."
                                      Value="{Binding Base64Value, Mode=TwoWay}" />
                <TextBlock Text="{Binding Base64Value.Length, StringFormat='Bound value: {0} bytes', FallbackValue='Bound value: (null)'}"
                           FontSize="12"
                           Foreground="{DynamicResource CobaltForegroundSecondaryBrush}" />
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</UserControl>
