<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:CobaltAvaloniaDesktopTester.ViewModels"
             xmlns:cobalt="using:Cobalt.Avalonia.Desktop.Controls"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:pia="using:PhosphorIconsAvalonia.Markup"
             mc:Ignorable="d" d:DesignWidth="600" d:DesignHeight="700"
             x:Class="CobaltAvaloniaDesktopTester.Views.SettingsPageView"
             x:DataType="vm:SettingsPageViewModel">

    <ScrollViewer>
        <StackPanel Margin="24" Spacing="16">
            <TextBlock Text="Settings"
                       FontSize="24"
                       FontWeight="SemiBold" />
            <TextBlock Text="Manage application preferences and configuration."
                       Foreground="{DynamicResource CobaltForegroundSecondaryBrush}" />

            <!-- General -->
            <TextBlock Text="General"
                       FontSize="16"
                       FontWeight="SemiBold"
                       Margin="0,8,0,0" />

            <Border Background="{DynamicResource CobaltSurfaceBrush}"
                    BorderBrush="{DynamicResource CobaltBorderSubtleBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="16">
                <Grid ColumnDefinitions="Auto,*,Auto">
                    <!-- Icon container -->
                    <Border Grid.Column="0"
                            Width="40" Height="40"
                            VerticalAlignment="Center">
                        <PathIcon Data="{pia:IconGeometry Icon=moon}"
                                  Width="20" Height="20"
                                  Foreground="{DynamicResource CobaltForegroundBrush}" />
                    </Border>

                    <!-- Header + Description -->
                    <StackPanel Grid.Column="1"
                                VerticalAlignment="Center"
                                Margin="12,0,12,0">
                        <TextBlock Text="Theme"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource CobaltForegroundBrush}" />
                        <TextBlock Text="Switch between light and dark mode"
                                   FontSize="12"
                                   TextWrapping="Wrap"
                                   Foreground="{DynamicResource CobaltForegroundSecondaryBrush}" />
                    </StackPanel>

                    <!-- Toggle Switch -->
                    <ToggleSwitch Grid.Column="2"
                                  VerticalAlignment="Center"
                                  IsChecked="{Binding IsDarkTheme, Mode=TwoWay}"
                                  OnContent="Dark"
                                  OffContent="Light" />
                </Grid>
            </Border>

            <cobalt:SettingsCardControl Header="Appearance"
                                        Description="Change theme, colors, and display options"
                                        IconData="{pia:IconGeometry Icon=palette}"
                                        Command="{Binding CardClickedCommand}"
                                        CommandParameter="Appearance" />

            <cobalt:SettingsCardControl Header="Language"
                                        Description="Set your preferred language and region"
                                        IconData="{pia:IconGeometry Icon=translate}"
                                        Command="{Binding CardClickedCommand}"
                                        CommandParameter="Language" />

            <!-- Security -->
            <TextBlock Text="Security"
                       FontSize="16"
                       FontWeight="SemiBold"
                       Margin="0,8,0,0" />

            <cobalt:SettingsCardControl Header="Encryption"
                                        Description="Configure default encryption algorithms and key sizes"
                                        IconData="{pia:IconGeometry Icon=lock_key}"
                                        Command="{Binding CardClickedCommand}"
                                        CommandParameter="Encryption" />

            <cobalt:SettingsCardControl Header="Key Management"
                                        Description="Manage stored keys, certificates, and trust settings"
                                        IconData="{pia:IconGeometry Icon=key}"
                                        Command="{Binding CardClickedCommand}"
                                        CommandParameter="Key Management" />

            <!-- About -->
            <TextBlock Text="About"
                       FontSize="16"
                       FontWeight="SemiBold"
                       Margin="0,8,0,0" />

            <!-- SettingsCardExpander Examples -->
            <cobalt:SettingsCardExpander Header="About this app"
                                         Description="View application details"
                                         IconData="{pia:IconGeometry Icon=info}">
                <TextBlock Text="Enigma is a desktop application for encryption and key management, built with Avalonia and the Enigma.Cryptography library."
                           TextWrapping="Wrap"
                           Foreground="{DynamicResource CobaltForegroundSecondaryBrush}" />
            </cobalt:SettingsCardExpander>

            <cobalt:SettingsCardExpander Header="Preferences"
                                         Description="Configure display and behavior options"
                                         IconData="{pia:IconGeometry Icon=gear}">
                <StackPanel Spacing="12">
                    <TextBox Watermark="Display name" />
                    <CheckBox Content="Enable notifications" />
                    <CheckBox Content="Use dark theme" />
                </StackPanel>
            </cobalt:SettingsCardExpander>

            <cobalt:SettingsCardExpander Header="Advanced"
                                         Description="Additional configuration options">
                <TextBlock Text="Advanced settings will be available in a future release."
                           TextWrapping="Wrap"
                           Foreground="{DynamicResource CobaltForegroundSecondaryBrush}" />
            </cobalt:SettingsCardExpander>

            <cobalt:SettingsCardControl Header="Updates"
                                        Description="Check for application updates"
                                        IconData="{pia:IconGeometry Icon=arrow_clockwise}"
                                        Command="{Binding CardClickedCommand}"
                                        CommandParameter="Updates" />

            <!-- Feedback -->
            <TextBlock Text="{Binding LastAction}"
                       IsVisible="{Binding LastAction, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                       FontWeight="SemiBold"
                       Margin="0,8,0,0" />
        </StackPanel>
    </ScrollViewer>
</UserControl>
