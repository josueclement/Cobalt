<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Enigma.Avalonia.App"
             xmlns:local="using:Enigma.Avalonia"
             RequestedThemeVariant="Dark">

    <Application.DataTemplates>
        <local:ViewLocator/>
    </Application.DataTemplates>
  
    <Application.Styles>
        <FluentTheme />
        <StyleInclude Source="/Controls/NavigationControl.axaml" />
        <StyleInclude Source="/Controls/NavigationItemControl.axaml" />
    </Application.Styles>
</Application>