<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="using:Enigma.Avalonia.Controls">

    <Design.PreviewWith>
        <controls:NavigationItemControl Header="Keys"
                                        IconData="M12.5 2a4.5 4.5 0 0 0-4.41 5.39L2 13.5V16h2.5v-2H7v-2h2l1.11-1.09A4.5 4.5 0 1 0 12.5 2Zm1.5 5a1.5 1.5 0 1 1 0-3 1.5 1.5 0 0 1 0 3Z"
                                        Width="80"
                                        Height="60" />
    </Design.PreviewWith>

    <Style Selector="controls|NavigationItemControl">
        <Setter Property="Template">
            <ControlTemplate>
                <StackPanel HorizontalAlignment="Center"
                            Margin="0,4">
                    <PathIcon Data="{TemplateBinding IconData}"
                              Width="24" Height="24"
                              HorizontalAlignment="Center" />
                    <TextBlock Text="{TemplateBinding Header}"
                               FontSize="11"
                               HorizontalAlignment="Center"
                               Margin="0,4,0,0" />
                </StackPanel>
            </ControlTemplate>
        </Setter>
    </Style>
</Styles>
